.env
.envrc
.venv
env/
venv/
ENV/

# IDE Settings (VS Code, Jupyter, etc.)
.vscode/
.ipynb_checkpoints
.idea/
*.swp

# Operating System Files
.DS_Store
Thumbs.db

# ====================================================================
# CUSTOM PROJECT RULES: INDONESIAN MID-CAP ANALYZER
# ====================================================================

# 1. SECURITY: Keep your local paths and API keys private
config.py

# 2. STORAGE: Ignore heavy/original data folders
# These match your RAW_DATA_PATH and INGESTED_DATA_PATH variables
Raw_Data/
Ingested_Data/
Clean_Master_Data/
Daftar_Saham/
*.xlsx
*.csv

# 3. EXCEPTION: Force-include only the Masked CSVs for your portfolio
# We ignore all CSVs above, then allow only the ones in Masked_Data
!Masked_Data/
!Masked_Data/*.csv
